generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        BigInt   @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  users     User[]
  projects  Project[]
}

model User {
  id        BigInt   @id @default(autoincrement())
  
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  
  organizationId BigInt?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  
  projects  Project[] @relation("ProjectOwner")
  assignedTasks TaskAssignment[] @relation("TaskAssignee")
  createdAssignments TaskAssignment[] @relation("AssignmentCreator")
  timeLogs  TimeLog[]
}

model Project {
  id          BigInt        @id @default(autoincrement())
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  
  organizationId BigInt?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  ownerId   BigInt
  owner     User     @relation("ProjectOwner", fields: [ownerId], references: [id])

  tasks     Task[]
}

model Task {
  id          BigInt   @id @default(autoincrement())
  title       String
  status      TaskStatus @default(TODO)
  priority    Int
  createdAt   DateTime @default(now())

  projectId   BigInt
  project     Project  @relation(fields: [projectId], references: [id])

  assignments TaskAssignment[]
  timeLogs    TimeLog[]
}

model TaskAssignment {
  id        BigInt   @id @default(autoincrement())
  taskId    BigInt
  userId    BigInt
  assignedAt DateTime @default(now())
  assignedBy BigInt
  
  task      Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User @relation("TaskAssignee", fields: [userId], references: [id], onDelete: Cascade)
  assigner  User @relation("AssignmentCreator", fields: [assignedBy], references: [id])
  
  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
  @@index([assignedBy])
}

model TimeLog {
  id        BigInt   @id @default(autoincrement())
  startTime DateTime @default(now())
  endTime   DateTime?
  duration  Int?
  title     String?

  userId    BigInt
  user      User     @relation(fields: [userId], references: [id])

  taskId    BigInt
  task      Task     @relation(fields: [taskId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId, taskId])
}

enum Role {
  ADMIN
  USER
  MANAGER
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}